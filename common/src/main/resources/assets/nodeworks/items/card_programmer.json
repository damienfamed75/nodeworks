{
  "model": {
    "type": "minecraft:select",
    "property": "nodeworks:card_programmer_card_type",
    "cases": [
      {
        "when": "storage",
        "model": {
          "type": "minecraft:model",
          "model": "nodeworks:item/card_programmer_storage"
        }
      },
      {
        "when": "io",
        "model": {
          "type": "minecraft:model",
          "model": "nodeworks:item/card_programmer_io"
        }
      },
      {
        "when": "redstone",
        "model": {
          "type": "minecraft:model",
          "model": "nodeworks:item/card_programmer_redstone"
        }
      }
    ],
    "fallback": {
      "type": "minecraft:model",
      "model": "nodeworks:item/card_programmer"
    }
  }
}
